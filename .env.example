# --- Provider (sidecar) ---
PORT=19131
# Inference backend (any OpenAI-compatible server):
#   Qwen llamafile (default): http://localhost:8080
#   Ollama:                   http://localhost:11434
#   Hosted (Groq/OpenAI/...): their base URL + INFERENCE_API_KEY below
INFERENCE_BASE=http://localhost:8080
INFERENCE_API_KEY=
MODEL=qwen2.5-0.5b-instruct

# Pricing — pay-per-second in USDC (6-decimal asset on Arc)
PRICE_USDC_PER_SECOND=0.0002
PRICE_TICK_SECONDS=1
MIN_CHARGE_USDC=0.000001
MAX_SESSION_SECONDS=600
PULL_GRACE_SECONDS=8

# Idle gating — only serve when the machine is idle (optional)
REQUIRE_IDLE=false
IDLE_THRESHOLD_SECONDS=60

# --- Payment (real Circle x402 on Arc, no mock) ---
# Seller wallet that receives USDC into its Gateway balance.
SELLER_ADDRESS=0xYourSellerAddress
ARC_CHAIN=arcTestnet

# --- Buyer agent ---
# Funded at https://faucet.circle.com
BUYER_PRIVATE_KEY=0xYourBuyerPrivateKey
BASE_URL=http://localhost:19131
DEPOSIT_AMOUNT=1
